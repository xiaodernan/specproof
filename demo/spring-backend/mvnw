# Maven Wrapper startup script (Unix/POSIX sh)
# Uses .mvn/wrapper/maven-wrapper.jar to bootstrap Maven.

PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

# Resolve JAVA_HOME
if [ -z "$JAVA_HOME" ]; then
  JAVA_EXEC=$(command -v java 2>/dev/null)
  if [ -n "$JAVA_EXEC" ]; then
    JAVA_HOME=$(dirname $(dirname $(readlink -f "$JAVA_EXEC" 2>/dev/null || echo "$JAVA_EXEC")))
  fi
fi

if [ -z "$JAVA_HOME" ]; then
  echo "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
  echo "Please set the JAVA_HOME variable in your environment to match the" >&2
  echo "location of your Java installation." >&2
  exit 1
fi

JAVACMD="$JAVA_HOME/bin/java"

# Maven Wrapper configuration
MAVEN_PROJECTBASEDIR="${MAVEN_PROJECTBASEDIR:-$(pwd)}"
export MAVEN_PROJECTBASEDIR

WRAPPER_JAR="$APP_HOME/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$APP_HOME/.mvn/wrapper/maven-wrapper.properties"

# Read the distributionUrl from maven-wrapper.properties
DIST_URL=$(grep '^distributionUrl=' "$WRAPPER_PROPERTIES" 2>/dev/null | cut -d'=' -f2-)
DIST_SHA256=$(grep '^distributionSha256Sum=' "$WRAPPER_PROPERTIES" 2>/dev/null | cut -d'=' -f2-)

MAVEN_WRAPPER_PROPERTIES="$WRAPPER_PROPERTIES"
export MAVEN_WRAPPER_PROPERTIES

# Use the wrapper jar to launch Maven
exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.home=${M2_HOME:-}" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  ${WRAPPER_LAUNCHER:-org.apache.maven.wrapper.MavenWrapperMain} \
  "$@"
