# SpecProof Phase 0
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================================
# LLM Provider
# ============================================================
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://your-provider.example.com/v1
LLM_API_KEY=replace_me
LLM_MODEL=deepseek-v4-pro
LLM_THINKING_ENABLED=false
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=2

# ============================================================
# MySQL (Phase 0 — business truth)
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=specproof_phase0
MYSQL_USER=specproof
MYSQL_PASSWORD=replace_me
MYSQL_ROOT_PASSWORD=replace_me

# ============================================================
# MongoDB (Phase 0 — analysis artifacts)
# ============================================================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=specproof_phase0
MONGODB_USER=specproof
MONGODB_PASSWORD=replace_me

# ============================================================
# Elasticsearch (Phase 0 — code retrieval)
# ============================================================
ES_HOST=http://localhost:9200
ES_USER=elastic
ES_PASSWORD=replace_me

# ============================================================
# Redis (Phase 0 — cache, locks, progress)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_me

# ============================================================
# RabbitMQ (Phase 0 — task pipeline)
# ============================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=specproof
RABBITMQ_PASSWORD=replace_me

# ============================================================
# MinIO (Phase 0 — object storage)
# ============================================================
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_me
MINIO_SECURE=false
